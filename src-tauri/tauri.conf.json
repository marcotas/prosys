{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ProSys",
  "version": "0.3.1",
  "identifier": "com.prosys.app",
  "build": {
    "frontendDist": "../build/client",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev --host",
    "beforeBuildCommand": "pnpm build && node scripts/prepare-server-bundle.js"
  },
  "app": {
    "windows": [
      {
        "title": "ProSys",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "server-bundle/": "server/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGMEQ5OUUwOTM4NzAwQjkKUldTNUFJZVQ0SmtOdittdVp6RUtSakdERVlSYVdEd2RUQnhlZGRCSWJDaDM0TUN6M2ppV0o0cTMK",
      "endpoints": [
        "https://github.com/marcotas/prosys/releases/latest/download/latest.json"
      ]
    }
  }
}
